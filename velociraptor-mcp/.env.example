# Velociraptor MCP Server credentials — copy this to .env and fill in your values
#
# VELOCIRAPTOR_API_KEY is the filename (or path) of your Velociraptor api.config.yaml.
# Use a plain filename here — the wrapper script resolves it to an absolute path
# automatically, so the same .env works on both the macOS host and inside the container.
#
# To generate api.config.yaml on your Velociraptor server:
#   velociraptor config api_client --name talon > api.config.yaml
# Then copy the file into this directory (velociraptor-mcp/).
VELOCIRAPTOR_API_KEY=api.config.yaml

# Set to "false" to skip SSL verification for self-signed certs
VELOCIRAPTOR_SSL_VERIFY=true

# Request timeout in seconds (default: 30)
VELOCIRAPTOR_TIMEOUT=30
