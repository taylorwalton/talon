# Wazuh MCP Server credentials — copy this to .env and fill in your values
WAZUH_PROD_URL=https://your-wazuh-host:55000
WAZUH_PROD_USERNAME=your-username
WAZUH_PROD_PASSWORD=your-password

# Set to "false" to skip SSL verification for self-signed certs
WAZUH_PROD_SSL_VERIFY=false

# Request timeout in seconds (default: 30)
WAZUH_PROD_TIMEOUT=30
