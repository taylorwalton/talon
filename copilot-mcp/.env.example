# CoPilot MCP Server credentials — copy this to .env and fill in your values
COPILOT_URL=http://your-copilot-host:5000
COPILOT_USERNAME=your-username
COPILOT_PASSWORD=your-password

# Set to "false" to skip SSL verification for self-signed certs
COPILOT_SSL_VERIFY=false

# Request timeout in seconds (default: 30)
COPILOT_TIMEOUT=30
